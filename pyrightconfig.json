{
  "pythonVersion": "3.14",
  "typeCheckingMode": "standard",
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "reportMissingTypeStubs": "none",
  "include": [
    "regfinder",
    "tests",
    "tools",
    "사내 규정검색기 v9 PyQt6.py"
  ],
  "exclude": [
    "**/__pycache__",
    ".pytest_cache",
    ".pytest_localappdata",
    ".regfinder_logs",
    "build",
    "dist",
    "docs",
    "logs",
    "artifacts",
    "models",
    "__pycache__"
  ],
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "."
      ]
    }
  ]
}
